/* ---------------- RECEIVE PREDICTION FROM ML SERVER ---------------- */

void receivePrediction()
{
  if (!server.hasArg("plain"))
  {
    Serial.println("No POST body received");
    server.send(400, "text/plain", "No JSON received");
    return;
  }

  String body = server.arg("plain");

  Serial.println("Prediction Received:");
  Serial.println(body);

  DynamicJsonDocument doc(512);

  DeserializationError error = deserializeJson(doc, body);

  if (error)
  {
    Serial.println("JSON Parsing Failed");
    server.send(400, "text/plain", "JSON Error");
    return;
  }

  String prediction = doc["prediction"];
  float confidence = doc["confidence"];
  String remedy = doc["remedy"];
  String phone = doc["phone"];

  Serial.println("----- RESULT -----");

  Serial.print("Disease: ");
  Serial.println(prediction);

  Serial.print("Confidence: ");
  Serial.println(confidence);

  Serial.print("Remedy: ");
  Serial.println(remedy);

  Serial.print("Farmer Number: +91934400");
  Serial.println(phone);

  Serial.println("------------------");

  /* Build SMS */

  String smsText = "";

  smsText += "Crop Disease Alert\n";
  smsText += "Disease: " + prediction;
  smsText += "\nConfidence: " + String(confidence,2) + "%";
  smsText += "\nRemedy: " + remedy;

  /* Send SMS */

  sendSMS(phone, smsText);
  Serial.println("Triggering WhatsApp...");
  sendWhatsApp(prediction, confidence, remedy);

  /* Respond to Python server */

  server.send(200, "application/json", "{\"status\":\"received\"}");
}

/* ---------------- SETUP ---------------- */

void setup()
{
  Serial.begin(115200);

  SIM800.begin(9600, SERIAL_8N1, 16, 17);

  delay(3000);

  Serial.println("SIM800 Starting...");

  initGSM();

  /* WIFI CONNECT */

  WiFi.begin(ssid, password);

  Serial.print("Connecting WiFi");

  while (WiFi.status() != WL_CONNECTED)
  {
    delay(500);
    Serial.print(".");
  }

  Serial.println();

  Serial.println("WiFi Connected");

  Serial.print("ESP32 IP: ");
  Serial.println(WiFi.localIP());

  Serial.print("MAC Address: ");
  Serial.println(WiFi.macAddress());

  /* HTTP ENDPOINT */

  server.on("/prediction", HTTP_POST, receivePrediction);

  server.begin();

  Serial.println("HTTP Server Started");
}

/* ---------------- LOOP ---------------- */

void loop()
{
  server.handleClient();

  /* GSM MESSAGE HANDLING */

  if (SIM800.available())
  {
    String line = SIM800.readStringUntil('\n');
    line.trim();

    if (line.length() == 0) return;

    Serial.println(line);

    if (line.startsWith("+CMT:"))
    {
      senderNumber = extractPhoneNumber(line);
      waitForMessage = true;
      return;
    }

    if (waitForMessage)
    {
      waitForMessage = false;

      Serial.println("Sender: " + senderNumber);
      Serial.println("Message: " + line);

      if (line == "hii")
      {
        sendSMS(senderNumber, "Hello Farmer!");
      }
    }
  }
}
