/* ---------------- SEND AT COMMAND ---------------- */

void sendCommand(String cmd, int waitTime)
{
  Serial.println("CMD: " + cmd);

  SIM800.println(cmd);
  delay(waitTime);

  while (SIM800.available())
  {
    Serial.write(SIM800.read());
  }

  Serial.println();
}

/* ---------------- EXTRACT PHONE NUMBER ---------------- */

String extractPhoneNumber(String input)
{
  int firstQuote = input.indexOf("\"") + 1;
  int secondQuote = input.indexOf("\"", firstQuote);

  if (firstQuote > 0 && secondQuote > firstQuote)
  {
    return input.substring(firstQuote, secondQuote);
  }

  return "";
}

/* ---------------- GET SMS CENTER NUMBER ---------------- */

void extractSMCA()
{
  SIM800.println("AT+CSCA?");
  delay(1000);

  while (SIM800.available())
  {
    String line = SIM800.readStringUntil('\n');
    line.trim();

    Serial.println(line);

    if (line.startsWith("+CSCA:"))
    {
      SMCANO = extractPhoneNumber(line);
      Serial.println("SMSC Number: " + SMCANO);
    }
  }
}

/* ---------------- SEND SMS ---------------- */

void sendSMS(String number, String text)
{
  Serial.println("Sending SMS...");

  SIM800.print("AT+CMGS=\"");
  SIM800.print(number);
  SIM800.println("\"");

  unsigned long start = millis();

  while (millis() - start < 5000)
  {
    if (SIM800.available())
    {
      char c = SIM800.read();
      Serial.write(c);

      if (c == '>')
      {
        break;
      }
    }
  }

  SIM800.print(text);
  delay(500);

  SIM800.write(26);

  Serial.println("\nSMS Sent Command Issued");
}
